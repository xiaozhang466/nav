<launch>
	<arg name="imu_package" default="spec" doc="package type [spec,0x91,0x62]"/>
	<arg name="serial_port" default="/dev/ttyimu"/>
	<arg name="baud" default="921600"/>
	<arg name="frame_id" default="base_link"/>
	<arg name="timer_period" default="0.0025"/>
	<arg name="orientation_covariance" default="[7.348567308716765e-05, -4.3882620070814594e-06, -3.473961286608797e-06, -4.3882620070814594e-06, 7.959353928652679e-05, 1.958731536376626e-06, -3.473961286608797e-06, 1.958731536376626e-06, 1.0603682546591704e-05]"/>
	<arg name="angular_velocity_covariance" default="[2.514820774702671e-06, 0.0, 0.0, 0.0, 2.840413507693534e-06, 0.0, 0.0, 0.0, 5.0e-05]"/>
	<arg name="linear_acceleration_covariance" default="[0.0017920532085053012, -6.73923279568846e-05, 0.006632258635135463, -6.73923279568846e-05, 0.002919701117708513, 0.0021246417831104454, 0.006632258635135463, 0.0021246417831104454, 0.05407291047401798]"/>
	<arg name="enable_debug_echo" default="true"/>
	
	<include file="$(find imu_launch)/launch/imu_$(arg imu_package)_msg.launch">
		<arg name="serial_port" value="$(arg serial_port)"/>
		<arg name="baud" value="$(arg baud)"/>
		<arg name="frame_id" value="$(arg frame_id)"/>
		<arg name="timer_period" value="$(arg timer_period)"/>
		<arg name="orientation_covariance" value="$(arg orientation_covariance)"/>
		<arg name="angular_velocity_covariance" value="$(arg angular_velocity_covariance)"/>
		<arg name="linear_acceleration_covariance" value="$(arg linear_acceleration_covariance)"/>
		<arg name="enable_debug_echo" value="$(arg enable_debug_echo)"/>
	</include>
	
</launch>
